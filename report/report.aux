\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Behavioral accuracy of Llama-3-8B-Instruct on 15 matched GSM8K problems with Wilson 95\% CIs. (a)~Overall accuracy with Fisher's exact $p$-value. (b)~Accuracy stratified by difficulty with per-bin sample sizes. All differences are non-significant at this sample size.}}{3}{figure.caption.1}\protected@file@percent }
