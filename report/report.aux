\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Prompt Frame Control}{4}{subsection.3.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Effect of prompt frame on P(correct answer). Three conditions: English question with English frame (blue), Turkish question with English frame (vermillion), and Turkish question with Turkish frame (teal, dashed). The Turkish-frame condition reveals that the model's apparent Turkish performance depends on English prompt scaffolding. Shaded bands show 95\% CI ($n = 15$).}}{4}{figure.caption.4}\protected@file@percent }
\newlabel{fig:frame}{{3}{4}{Effect of prompt frame on P(correct answer). Three conditions: English question with English frame (blue), Turkish question with English frame (vermillion), and Turkish question with Turkish frame (teal, dashed). The Turkish-frame condition reveals that the model's apparent Turkish performance depends on English prompt scaffolding. Shaded bands show 95\% CI ($n = 15$)}{figure.caption.4}{}}
