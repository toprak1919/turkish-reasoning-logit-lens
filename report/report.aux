\newlabel{fig:accuracy}{{1}{3}{Behavioral accuracy of Llama-3-8B-Instruct on 15 matched GSM8K problems with Wilson 95\% CIs. (a)~Overall accuracy with Fisher's exact $p$-value. (b)~Accuracy stratified by difficulty with per-bin sample sizes. All differences are non-significant at this sample size}{figure.caption.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Reasoning Trajectory Divergence}{3}{subsection.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Aggregate reasoning trajectory across 15 problems. Shaded regions show 95\% CI ($t$-distribution, $n = 15$). English and Turkish track identically through mid-layers before diverging sharply in the late layers. Dashed line marks median divergence onset (layer 27).}}{3}{figure.caption.2}\protected@file@percent }
\newlabel{fig:trajectory}{{2}{3}{Aggregate reasoning trajectory across 15 problems. Shaded regions show 95\% CI ($t$-distribution, $n = 15$). English and Turkish track identically through mid-layers before diverging sharply in the late layers. Dashed line marks median divergence onset (layer 27)}{figure.caption.2}{}}
